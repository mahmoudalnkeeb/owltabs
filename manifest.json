{
  "manifest_version": 3,
  "name": "OwlTabs",
  "version": "1.0.0",
  "description": "A focused new tab with RSS feeds, quick links, and AI.",
  "author": "Mahmoud Alnakeeb",
  "homepage_url": "https://github.com/mahmoudalnkeeb/owltabs",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://*/*"],
  "chrome_url_overrides": { "newtab": "src/newtab/index.html" },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
