{
  "name": "Vesper Agentic",
  "version": "1.0.0",
  "source": "Color values derived from the Vesper VS Code theme by Rauno Freiberg (https://github.com/raunofreiberg/vesper)",
  "color": {
    "surface": {
      "0": { "value": "#101010", "usage": "page canvas" },
      "1": { "value": "#161616", "usage": "cards, raised panels, active tabs" },
      "2": { "value": "#1C1C1C", "usage": "inputs, recessed wells, tool icons" },
      "3": { "value": "#202020", "usage": "modal / overlay base" },
      "selected": { "value": "#232323", "usage": "active list / menu selection" },
      "hover": { "value": "#282828", "usage": "hover state" }
    },
    "border": {
      "subtle": { "value": "#1D1D1D" },
      "default": { "value": "#282828" },
      "strong": { "value": "#343434" }
    },
    "text": {
      "primary": { "value": "#FFFFFF", "contrastOnSurface0": "19.0:1" },
      "secondary": { "value": "#A0A0A0", "contrastOnSurface0": "7.3:1" },
      "tertiary": { "value": "#7E7E7E", "contrastOnSurface0": "4.7:1", "note": "labels/captions only" },
      "disabled": { "value": "#505050" },
      "onAccent": { "value": "#000000", "contrastOnAccent": "13.9:1" }
    },
    "accent": {
      "description": "Agent / write-tier (peppermint orange)",
      "base": { "value": "#FFC799", "contrastOnSurface0": "12.6:1" },
      "hover": { "value": "#FFCFA8" },
      "soft": { "value": "#FFC79926" },
      "softer": { "value": "#FFC79914" }
    },
    "mint": {
      "description": "Positive / read-only-tier (peppermint mint)",
      "base": { "value": "#99FFE4", "contrastOnSurface0": "16.1:1" },
      "soft": { "value": "#99FFE426" },
      "softer": { "value": "#99FFE415" }
    },
    "red": {
      "description": "Negative / destructive",
      "base": { "value": "#FF8080", "contrastOnSurface0": "7.8:1" },
      "soft": { "value": "#FF808026" },
      "softer": { "value": "#FF808015" }
    },
    "selection": { "value": "#FFFFFF25" },
    "focusRing": { "value": "#FFC799" }
  },
  "trustTier": {
    "read": { "color": "mint.base", "meaning": "read-only, reversible by definition, never prompts" },
    "write": { "color": "accent.base", "meaning": "mutates state, always confirmable" },
    "danger": { "color": "red.base", "meaning": "destructive / irreversible, always confirmed" }
  },
  "agentState": {
    "idle":       { "orb": "ring paused, 28% opacity", "copy": "Ask Vesper anything…" },
    "listening":  { "orb": "glow pulse, 1.6s loop", "copy": "Listening…" },
    "thinking":   { "orb": "ring spin 1s/rev, amber→mint sweep", "copy": "Thinking for {n}s…" },
    "acting":     { "orb": "ring spin 0.55s/rev", "copy": "Running {tool}…" },
    "permission": { "orb": "ring frozen, red-amber pulse", "copy": "Needs your approval" },
    "streaming":  { "orb": "ring slows, sweep flips mint→amber", "copy": "(token stream)" },
    "done":       { "orb": "solid mint, static", "copy": "Done" },
    "error":      { "orb": "solid red, flashes 3×", "copy": "Couldn't complete — Retry" }
  },
  "radius": {
    "xs": { "value": "4px" }, "sm": { "value": "6px" }, "md": { "value": "10px" },
    "lg": { "value": "14px" }, "xl": { "value": "20px" }, "full": { "value": "999px" }
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px", "20": "80px"
  },
  "motion": {
    "duration": {
      "instant": "80ms", "fast": "120ms", "base": "200ms", "slow": "320ms", "deliberate": "480ms"
    },
    "easing": {
      "standard": "cubic-bezier(.4,0,.2,1)",
      "out": "cubic-bezier(0,0,.2,1)",
      "in": "cubic-bezier(.4,0,1,1)",
      "breath": "cubic-bezier(.45,0,.55,1)"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'Geist Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
    },
    "scale": {
      "display":  { "size": "56px", "lineHeight": 1.08, "weight": 600, "family": "sans" },
      "h1":       { "size": "36px", "lineHeight": 1.15, "weight": 600, "family": "sans" },
      "h2":       { "size": "26px", "lineHeight": 1.25, "weight": 600, "family": "sans" },
      "h3":       { "size": "19px", "lineHeight": 1.3,  "weight": 600, "family": "sans" },
      "bodyLg":   { "size": "17px", "lineHeight": 1.6,  "weight": 400, "family": "sans" },
      "body":     { "size": "15px", "lineHeight": 1.6,  "weight": 400, "family": "sans" },
      "bodySm":   { "size": "13px", "lineHeight": 1.55, "weight": 400, "family": "sans" },
      "caption":  { "size": "11px", "lineHeight": 1.4,  "weight": 500, "family": "mono", "transform": "uppercase", "tracking": "0.1em" },
      "code":     { "size": "13px", "lineHeight": 1.7,  "weight": 400, "family": "mono" }
    }
  },
  "zIndex": {
    "base": 1, "topbar": 10, "omnibox": 20, "drawer": 30, "permission": 40, "toast": 50
  }
}
